@page "/"
@implements IAsyncDisposable
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<BookstoreDb> DbContextFactory
@rendermode InteractiveServer

<PageTitle>Bookstore -  Home</PageTitle>

<div class="row mt-5 mx-auto">
    <div class="col-sm-2 border pt-3 me-3 mb-3">
        <a href="/books/create" class="btn btn-primary">Create New</a>
        <div class="mt-3">
            <input class="form-control text-muted" placeholder="Search..." @bind="searchFilter" @bind:event="oninput" />
        </div>


        <div class="mt-3">
            <h6> Filter by: </h6>
            <select class="form-select" @bind="genreFilter">
                <option value="">Genre</option>
                @if (genres != null)
                {
                    foreach (var genre in genres)
                    {
                        <option value="@genre">@genre</option>
                    }
                }
            </select>
            </div>
            <div class="mt-3">
                <h6> Sort by: </h6>
                <select class="form-select" @bind="sortPrice">
                    <option value="">Price</option>
                    <option value="asc">Lowest Price</option>
                    <option value="desc">Highest Price</option>
                </select>
            </div>
    </div>
    <div class="col">
        @if (books is null)
        {
            <p>Loading...</p>
        } else {
            <div class="hstack flex-wrap gap-3">
                @foreach (var book in paged) {
                    <BookCard Book="@book" />
                }
            </div>
            <nav class="mt-3">
                <ul class="pagination">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => currentPage = currentPage - 1">&laquo;</button>
                    </li>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        var p = i;
                        <li class="page-item @(currentPage == p ? "active" : "")">
                            <button class="page-link" @onclick="() => currentPage = p">@p</button>
                        </li>
                    }
                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="() => currentPage = currentPage + 1">&raquo;</button>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>


@code {
    private BookstoreDb context {get; set; }

    private IEnumerable<Book> books => context.Books.AsNoTracking();


    private string searchFilter { get; set; } = string.Empty;


    private string genreFilter { get; set; } = string.Empty;

    private string sortPrice { get; set; } = string.Empty;

    private IEnumerable<Book> filtered => books
        .Where(b => string.IsNullOrWhiteSpace(searchFilter)
            || b.Title.Contains(searchFilter, StringComparison.OrdinalIgnoreCase)
            || b.Author.Contains(searchFilter, StringComparison.OrdinalIgnoreCase))
        .Where(b => string.IsNullOrWhiteSpace(genreFilter) || b.Genre == genreFilter);

    private IEnumerable<Book> sorted => sortPrice switch
    {
        "asc" => filtered.OrderBy(b => b.Price),
        "desc" => filtered.OrderByDescending(b => b.Price),
        _ => filtered
    };

    private int currentPage { get; set; } = 1;
    private int pageSize = 3;
    private int totalPages => (int)Math.Ceiling((double)sorted.Count() / pageSize);
    private IEnumerable<Book> paged => sorted.Skip((currentPage - 1) * pageSize).Take(pageSize);

    private IEnumerable<string> genres => books.Select(b => b.Genre).Distinct();

    protected override void OnInitialized()
    {
        context = DbContextFactory.CreateDbContext();
    }

    public async ValueTask DisposeAsync()
    {
        if (context is not null)
        {
            await context.DisposeAsync();
        }
    }
}